generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  username     String   @unique
  passwordHash String   @map("password_hash")
  points       Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  squad        Squad?

  @@map("users")
}

model Squad {
  id        String        @id @default(uuid())
  userId    String        @unique @map("user_id")
  formation String        @default("4-3-3")
  budget    Float         @default(1000.0)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  players   SquadPlayer[]

  @@map("squads")
}

model SquadPlayer {
  id          String @id @default(uuid())
  squadId     String @map("squad_id")
  playerId    String @map("player_id")
  playerName  String @map("player_name")
  nationality String
  position    String
  slotIndex   Int    @map("slot_index")
  squad       Squad  @relation(fields: [squadId], references: [id], onDelete: Cascade)

  @@unique([squadId, slotIndex])
  @@map("squad_players")
}

model Match {
  id              String    @id @default(cuid())
  groupName       String    @map("group_name")
  homeTeam        String    @map("home_team")
  awayTeam        String    @map("away_team")
  homeNationality String    @map("home_nationality")
  awayNationality String    @map("away_nationality")
  homeFlag        String    @map("home_flag")
  awayFlag        String    @map("away_flag")
  homeScore       Int?      @map("home_score")
  awayScore       Int?      @map("away_score")
  status          String    @default("scheduled")
  matchDate       DateTime? @map("match_date")
  createdAt       DateTime  @default(now()) @map("created_at")

  @@map("matches")
}
